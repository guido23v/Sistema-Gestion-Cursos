<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestión de Cursos</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background-color: #f5f5f5;
            color: #333;
            line-height: 1.6;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }

        header {
            background: white;
            padding: 40px 0;
            margin-bottom: 40px;
            border-bottom: 1px solid #e0e0e0;
        }

        header h1 {
            font-size: 28px;
            font-weight: 600;
            margin-bottom: 8px;
        }

        header p {
            color: #666;
            font-size: 14px;
        }

        .layout {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
        }

        .card {
            background: white;
            border: 1px solid #e0e0e0;
            padding: 24px;
            border-radius: 4px;
        }

        .card h2 {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 20px;
            padding-bottom: 12px;
            border-bottom: 1px solid #e0e0e0;
        }

        .form-group {
            margin-bottom: 16px;
        }

        label {
            display: block;
            margin-bottom: 6px;
            font-size: 14px;
            font-weight: 500;
            color: #333;
        }

        input,
        textarea {
            width: 100%;
            padding: 10px 12px;
            border: 1px solid #d0d0d0;
            border-radius: 3px;
            font-size: 14px;
            font-family: inherit;
        }

        input:focus,
        textarea:focus {
            outline: none;
            border-color: #999;
            background-color: #fafafa;
        }

        textarea {
            resize: vertical;
            min-height: 80px;
        }

        button {
            background-color: #2c3e50;
            color: white;
            padding: 10px 20px;
            border: none;
            border-radius: 3px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: background-color 0.2s;
        }

        button:hover {
            background-color: #1a252f;
        }

        button:active {
            opacity: 0.9;
        }

        .btn-refresh {
            width: 100%;
            margin-bottom: 16px;
        }

        .btn-delete {
            background-color: #c0392b;
            padding: 6px 12px;
            font-size: 13px;
            margin-top: 12px;
        }

        .btn-delete:hover {
            background-color: #a93226;
        }

        .message {
            padding: 12px 16px;
            border-radius: 3px;
            margin-bottom: 16px;
            display: none;
            font-size: 14px;
            border-left: 4px solid;
        }

        .message.success {
            background-color: #d4edda;
            color: #155724;
            border-left-color: #28a745;
        }

        .message.error {
            background-color: #f8d7da;
            color: #721c24;
            border-left-color: #f5c6cb;
        }

        .cursos-list {
            max-height: 500px;
            overflow-y: auto;
        }

        .curso-item {
            background-color: #fafafa;
            padding: 16px;
            margin-bottom: 12px;
            border: 1px solid #e0e0e0;
            border-radius: 3px;
        }

        .curso-item:hover {
            background-color: #f9f9f9;
        }

        .curso-item h3 {
            font-size: 15px;
            font-weight: 600;
            margin-bottom: 6px;
            color: #2c3e50;
        }

        .curso-item p {
            font-size: 13px;
            color: #666;
            margin-bottom: 8px;
            line-height: 1.4;
        }

        .curso-item .dates {
            font-size: 12px;
            color: #999;
        }

        .loading {
            display: none;
            text-align: center;
            color: #999;
            font-size: 14px;
            padding: 20px;
        }

        .empty-message {
            text-align: center;
            color: #999;
            padding: 30px 20px;
            font-size: 14px;
        }

        @media (max-width: 768px) {
            .layout {
                grid-template-columns: 1fr;
            }

            header h1 {
                font-size: 22px;
            }

            .container {
                padding: 16px;
            }
        }

        /* Scrollbar personalizado */
        .cursos-list::-webkit-scrollbar {
            width: 6px;
        }

        .cursos-list::-webkit-scrollbar-track {
            background: #f1f1f1;
        }

        .cursos-list::-webkit-scrollbar-thumb {
            background: #bbb;
            border-radius: 3px;
        }

        .cursos-list::-webkit-scrollbar-thumb:hover {
            background: #999;
        }
    </style>
</head>
<body>
    <header>
        <div class="container">
            <h1>Gestión de Cursos</h1>
            <p>Sistema simple para administrar tus cursos</p>
        </div>
    </header>

    <div class="container">
        <div class="layout">
            <!-- Formulario para crear curso -->
            <div class="card">
                <h2>Crear Curso</h2>
                <div id="createMessage" class="message"></div>

                <form id="createForm">
                    <div class="form-group">
                        <label for="nombre">Nombre del Curso</label>
                        <input type="text" id="nombre" name="nombre" required placeholder="Ej: Python Avanzado">
                    </div>

                    <div class="form-group">
                        <label for="descripcion">Descripción</label>
                        <textarea id="descripcion" name="descripcion" placeholder="Describe el contenido del curso..."></textarea>
                    </div>

                    <div class="form-group">
                        <label for="fechaInicio">Fecha de Inicio</label>
                        <input type="date" id="fechaInicio" name="fechaInicio" required>
                    </div>

                    <div class="form-group">
                        <label for="fechaFin">Fecha de Fin</label>
                        <input type="date" id="fechaFin" name="fechaFin" required>
                    </div>

                    <button type="submit">Guardar Curso</button>
                </form>
            </div>

            <!-- Lista de cursos -->
            <div class="card">
                <h2>Cursos Registrados</h2>
                <button class="btn-refresh" onclick="loadCursos()">Actualizar Lista</button>

                <div id="loadingMessage" class="loading">Cargando...</div>
                <div id="cursosList" class="cursos-list">
                    <div class="empty-message">No hay cursos registrados</div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const API_BASE = 'http://localhost:5000/api';

        document.addEventListener('DOMContentLoaded', () => {
            loadCursos();
            setupFormSubmit();
        });

        function setupFormSubmit() {
            document.getElementById('createForm').addEventListener('submit', async (e) => {
                e.preventDefault();
                await createCurso();
            });
        }

        async function loadCursos() {
            const loadingMsg = document.getElementById('loadingMessage');
            const cursosList = document.getElementById('cursosList');

            loadingMsg.style.display = 'block';
            cursosList.innerHTML = '';

            try {
                const response = await fetch(`${API_BASE}/cursos`);
                const cursos = await response.json();

                loadingMsg.style.display = 'none';

                if (!cursos || cursos.length === 0) {
                    cursosList.innerHTML = '<div class="empty-message">No hay cursos registrados</div>';
                    return;
                }

                cursosList.innerHTML = cursos.map(curso => `
                    <div class="curso-item">
                        <h3>${curso.nombre}</h3>
                        <p>${curso.descripcion || 'Sin descripción'}</p>
                        <div class="dates">${formatDate(curso.fechaInicio)} - ${formatDate(curso.fechaFin)}</div>
                        <button class="btn-delete" onclick="deleteCurso(${curso.cursoId})">Eliminar</button>
                    </div>
                `).join('');
            } catch (error) {
                loadingMsg.style.display = 'none';
                cursosList.innerHTML = '<div class="empty-message">Error al cargar los cursos</div>';
                console.error('Error:', error);
            }
        }

        async function createCurso() {
            const nombre = document.getElementById('nombre').value;
            const descripcion = document.getElementById('descripcion').value;
            const fechaInicio = document.getElementById('fechaInicio').value;
            const fechaFin = document.getElementById('fechaFin').value;
            const messageDiv = document.getElementById('createMessage');

            messageDiv.className = 'message';
            messageDiv.textContent = '';

            try {
                const response = await fetch(`${API_BASE}/cursos`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        nombre,
                        descripcion,
                        fechaInicio: fechaInicio + 'T00:00:00',
                        fechaFin: fechaFin + 'T00:00:00'
                    })
                });

                if (!response.ok) throw new Error('Error al crear el curso');

                messageDiv.className = 'message success';
                messageDiv.textContent = 'Curso creado exitosamente';

                document.getElementById('createForm').reset();
                await new Promise(resolve => setTimeout(resolve, 1500));
                loadCursos();
            } catch (error) {
                messageDiv.className = 'message error';
                messageDiv.textContent = 'Error: ' + error.message;
                console.error('Error:', error);
            }
        }

        async function deleteCurso(id) {
            if (!confirm('¿Deseas eliminar este curso?')) return;

            try {
                const response = await fetch(`${API_BASE}/cursos/${id}`, {
                    method: 'DELETE'
                });

                if (!response.ok) throw new Error('Error al eliminar');

                loadCursos();
            } catch (error) {
                alert('Error: ' + error.message);
                console.error('Error:', error);
            }
        }

        function formatDate(dateString) {
            const date = new Date(dateString);
            return date.toLocaleDateString('es-ES', {
                year: 'numeric',
                month: 'short',
                day: 'numeric'
            });
        }
    </script>
</body>
</html>
